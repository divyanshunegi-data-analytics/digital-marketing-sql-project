-- marketing_campaign_analysis using SQL
-- Solutions of 15 business problems

-- Q1: Which platform generated the highest revenue?
SELECT platform, SUM(revenue) AS total_revenue
FROM marketing_ads
GROUP BY platform
ORDER BY total_revenue DESC;


-- Q2: Which country has the highest number of conversions?
SELECT country, SUM(conversions) AS total_conversions
FROM marketing_ads
GROUP BY country
ORDER BY total_conversions DESC;


-- Q3: Which campaign type has the best performance based on conversions?
SELECT campaign_type, SUM(conversions) AS total_conversions
FROM marketing_ads
GROUP BY campaign_type
ORDER BY total_conversions DESC;


-- Q4: Which industry spends the most on advertising?
SELECT industry, SUM(ad_spend) AS total_spend
FROM marketing_ads
GROUP BY industry
ORDER BY total_spend DESC;


-- Q5: Which platform has the highest average ROAS?
SELECT platform, AVG(ROAS) AS avg_roas
FROM marketing_ads
GROUP BY platform
ORDER BY avg_roas DESC;


-- Q6: What are the top 5 campaign types by revenue?
SELECT campaign_type, SUM(revenue) AS total_revenue
FROM marketing_ads
GROUP BY campaign_type
ORDER BY total_revenue DESC
LIMIT 5;


-- Q7: Which country has the highest average CTR?
SELECT country, AVG(CTR) AS avg_ctr
FROM marketing_ads
GROUP BY country
ORDER BY avg_ctr DESC;


-- Q8: Which platform has the lowest average CPC?
SELECT platform, AVG(CPC) AS avg_cpc
FROM marketing_ads
GROUP BY platform
ORDER BY avg_cpc ASC;


-- Q9: What is the daily revenue trend?
SELECT date, SUM(revenue) AS daily_revenue
FROM marketing_ads
GROUP BY date
ORDER BY date;


-- Q10: What is the conversion rate by platform?
SELECT 
platform,
SUM(conversions) / SUM(clicks) AS conversion_rate
FROM marketing_ads
GROUP BY platform;


-- Q11: What is the total revenue generated by each industry?
SELECT industry, SUM(revenue) AS total_revenue
FROM marketing_ads
GROUP BY industry
ORDER BY total_revenue DESC;


-- Q12: Which record has the highest ad spend?
SELECT *
FROM marketing_ads
ORDER BY ad_spend DESC
LIMIT 1;


-- Q13: Which record has the highest revenue?
SELECT *
FROM marketing_ads
ORDER BY revenue DESC
LIMIT 1;


-- Q14: What is the total number of clicks per platform?
SELECT platform, SUM(clicks) AS total_clicks
FROM marketing_ads
GROUP BY platform
ORDER BY total_clicks DESC;


-- Q15: Which platform and campaign type combination performs best in terms of revenue?
SELECT platform, campaign_type, SUM(revenue) AS total_revenue
FROM marketing_ads
GROUP BY platform, campaign_type
ORDER BY total_revenue DESC;
